<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.Vidygo.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <item name="windowSplashScreenBackground">@color/appbar_primary</item>
        <item name="postSplashScreenTheme">@style/Theme.Vidygo</item>
    </style>

    <!-- Base application theme. -->
    <style name="Theme.Vidygo" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color - Modern minimalist AppBar -->
        <item name="colorPrimary">@color/appbar_primary</item>
        <item name="colorPrimaryVariant">@color/appbar_primary</item>
        <item name="colorOnPrimary">@color/appbar_text</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- Status bar color - Subtle dark gray for contrast -->
        <item name="android:statusBarColor">@color/appbar_primary</item>
        <!-- Customize your theme here. -->
    </style>
</resources>