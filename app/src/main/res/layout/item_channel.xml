<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:padding="8dp"
    android:background="?attr/selectableItemBackground">

    <!-- Avatar circulaire de la chaîne -->
    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/channel_thumbnail"
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:contentDescription="@string/channel_thumbnail_desc"
        android:scaleType="centerCrop"
        android:src="@drawable/channel_avatar_placeholder"
        app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay_Vidygo_ChannelAvatar" />

    <!-- Nom de la chaîne -->
    <TextView
        android:id="@+id/channel_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:ellipsize="end"
        android:gravity="center"
        android:maxLines="2"
        android:textColor="@color/black"
        android:textSize="12sp"
        android:textStyle="bold" />

    <!-- Nombre de vidéos -->
    <TextView
        android:id="@+id/channel_count"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:gravity="center"
        android:textColor="@color/teal_700"
        android:textSize="11sp" />

</LinearLayout>
