<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.Vidygo.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <item name="windowSplashScreenBackground">@color/appbar_primary</item>
        <item name="postSplashScreenTheme">@style/Theme.Vidygo</item>
    </style>

    <!-- Base application theme. -->
    <style name="Theme.Vidygo" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color - Modern minimalist AppBar (dark) -->
        <item name="colorPrimary">@color/appbar_primary</item>
        <item name="colorPrimaryVariant">@color/appbar_primary</item>
        <item name="colorOnPrimary">@color/appbar_text</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/purple_matte_light</item>
        <item name="colorSecondaryVariant">@color/purple_matte</item>
        <item name="colorOnSecondary">@color/white</item>
        <!-- Customize your theme here. -->
    </style>
</resources>